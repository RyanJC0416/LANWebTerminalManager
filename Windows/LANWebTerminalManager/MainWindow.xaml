<Window x:Class="LANWebTerminalManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="局域网网页终端管理器"
        Width="1120"
        Height="720"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" CornerRadius="5" Background="White" BorderBrush="#2E000000" BorderThickness="1">
                            <TextBlock Text="LWM" FontWeight="Black" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="网页终端" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <Button Grid.Column="2" Content="设置" Padding="8,4" Margin="0,0,4,0" Click="OpenSettings_Click" ToolTip="接收方与目标服务器设置"/>
                        <Button Grid.Column="3" Content="+" Width="28" Height="28" Padding="0" Click="AddEndpoint_Click" ToolTip="添加网页终端"/>
                        <Button Grid.Column="4" Content="×" Width="28" Height="28" Padding="0" Margin="4,0,0,0" Click="RemoveSelected_Click" ToolTip="删除选中的网页终端"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="10,0,10,8">
                    <ComboBox x:Name="TargetPicker" SelectionChanged="TargetPicker_SelectionChanged"/>
                </Border>

                <ListBox x:Name="EndpointList"
                         Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="8"
                         SelectionChanged="EndpointList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#A8B0B9" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding HostPortLabel}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="3" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="UpdateStatusText" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="UpdateProgress" Height="6" Margin="0,6,0,0" Visibility="Collapsed"/>
                        <Button x:Name="UpdateButton" Content="检查更新" Margin="0,8,0,0" HorizontalAlignment="Left" Click="UpdateButton_Click"/>
                        <TextBlock x:Name="VersionText" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="10,8">
                    <Grid>
                        <TextBlock x:Name="ActivityText" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <ProgressBar x:Name="BusyIndicator" Width="18" Height="18" HorizontalAlignment="Right" IsIndeterminate="True" Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="76" Height="76" CornerRadius="14" Background="White" BorderBrush="#2E000000" BorderThickness="1">
                    <TextBlock Text="LWM" FontWeight="Black" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="还没有网页终端" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="添加一个包含 HTML 或 Markdown 的目录来开始管理局域网网页服务。"
                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="420"/>
            </StackPanel>

            <ScrollViewer x:Name="DetailPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="DetailTitle" FontSize="24" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DetailRootPath" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="RefreshAssetsButton" Content="刷新资产" Margin="0,0,8,0" Click="RefreshAssets_Click"/>
                                <Button x:Name="StopButton" Content="停止" Margin="0,0,8,0" Click="StopSelected_Click"/>
                                <Button x:Name="StartButton" Content="启动" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="StartSelected_Click"/>
                                <Button x:Name="OpenButton" Content="打开" Click="OpenUrl_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Margin="18">
                        <GroupBox Header="服务设置">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameInput" Margin="0,0,0,12" TextChanged="EndpointField_Changed"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="目录" VerticalAlignment="Center"/>
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="RootPathText" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="目录" Margin="8,0,0,0" Click="RevealFolder_Click"/>
                                </Grid>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="监听" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <ComboBox x:Name="HostInput" Width="160" SelectionChanged="EndpointField_Changed">
                                        <ComboBoxItem Content="局域网" Tag="0.0.0.0"/>
                                        <ComboBoxItem Content="本机" Tag="127.0.0.1"/>
                                    </ComboBox>
                                    <TextBox x:Name="PortInput" Width="76" Margin="12,0,0,0" TextChanged="EndpointField_Changed"/>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="入口" VerticalAlignment="Center"/>
                                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="UrlPathText" FontFamily="Consolas" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MouseLeftButtonUp="ChooseHomepage_Click" Cursor="Hand"/>
                                    <Button Grid.Column="1" Content="选择主页" Margin="8,0,0,0" Click="ChooseHomepage_Click"/>
                                </Grid>

                                <CheckBox Grid.Row="4" Grid.Column="1" x:Name="AutoOpenInput" Content="启动后自动打开" Checked="EndpointField_Changed" Unchecked="EndpointField_Changed"/>
                            </Grid>
                        </GroupBox>

                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <Border Margin="0,0,6,0" Padding="12" Background="{StaticResource ControlBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="82">
                                <StackPanel>
                                    <TextBlock Text="状态" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="StatusValue" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="3,0" Padding="12" Background="{StaticResource ControlBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="82">
                                <StackPanel>
                                    <TextBlock Text="页面" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="PageCountValue" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="3,0" Padding="12" Background="{StaticResource ControlBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="82">
                                <StackPanel>
                                    <TextBlock Text="PID" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="PidValue" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="6,0,0,0" Padding="12" Background="{StaticResource ControlBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="82">
                                <StackPanel>
                                    <TextBlock Text="索引" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="IndexMtimeValue" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <GroupBox Header="局域网访问地址">
                            <StackPanel>
                                <StackPanel x:Name="UrlList"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="CopyUrlsButton" Content="复制" Margin="0,0,8,0" Click="CopyUrls_Click"/>
                                    <Button x:Name="OpenLocalButton" Content="打开本机地址" Click="OpenLocalUrl_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="维护终端">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CommandInput"/>
                                    <Button Grid.Column="1" Content="执行" Margin="8,0,0,0" Click="RunCommand_Click"/>
                                </Grid>
                                <Border Background="{StaticResource MonoBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="140">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                        <TextBlock x:Name="TerminalOutputText" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="服务日志">
                            <Border Background="{StaticResource MonoBgBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" MinHeight="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                    <TextBlock x:Name="LogOutputText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </GroupBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
